# Naming styles

dotnet_naming_style.pascalcase.required_prefix =
dotnet_naming_style.pascalcase.required_suffix =
dotnet_naming_style.pascalcase.word_separator =
dotnet_naming_style.pascalcase.capitalization = pascal_case

dotnet_naming_style.ipascalcase.required_prefix = I
dotnet_naming_style.ipascalcase.required_suffix =
dotnet_naming_style.ipascalcase.word_separator =
dotnet_naming_style.ipascalcase.capitalization = pascal_case

dotnet_naming_style.tpascalcase.required_prefix = T
dotnet_naming_style.tpascalcase.required_suffix =
dotnet_naming_style.tpascalcase.word_separator =
dotnet_naming_style.tpascalcase.capitalization = pascal_case

dotnet_naming_style._camelcase.required_prefix = _
dotnet_naming_style._camelcase.required_suffix =
dotnet_naming_style._camelcase.word_separator =
dotnet_naming_style._camelcase.capitalization = camel_case

dotnet_naming_style.camelcase.required_prefix =
dotnet_naming_style.camelcase.required_suffix =
dotnet_naming_style.camelcase.word_separator =
dotnet_naming_style.camelcase.capitalization = camel_case

dotnet_naming_style.s_camelcase.required_prefix = s_
dotnet_naming_style.s_camelcase.required_suffix =
dotnet_naming_style.s_camelcase.word_separator =
dotnet_naming_style.s_camelcase.capitalization = camel_case

dotnet_naming_style.pascalcaseasync.required_prefix =
dotnet_naming_style.pascalcaseasync.required_suffix = Async
dotnet_naming_style.pascalcaseasync.word_separator =
dotnet_naming_style.pascalcaseasync.capitalization = pascal_case

#### CodeQuality ####
# dotnet_analyzer_diagnostic.category-CodeQuality.severity = warning
# dotnet_analyzer_diagnostic.category-Style.severity = warning

# 名前を簡略化する
dotnet_diagnostic.IDE0001.severity = warning
# 型メンバーアクセスを簡略化する
dotnet_diagnostic.IDE0002.severity = warning
# 不要なキャストを削除する
dotnet_diagnostic.IDE0004.severity = warning
# 不要な using ディレクティブを削除する
dotnet_diagnostic.IDE0005.severity = warning
# 不足しているケースを switch ステートメントに追加する
dotnet_diagnostic.IDE0010.severity = suggestion
# 到達できないコードを削除する (return, throw など)
dotnet_diagnostic.IDE0035.severity = warning
# 未使用のプライベートメンバーを削除する
dotnet_diagnostic.IDE0051.severity = warning
# 未読のプライベートメンバーを削除する
dotnet_diagnostic.IDE0052.severity = warning
# フォーマットを修正する
dotnet_diagnostic.IDE0055.severity = warning
# 構造体フィールドを書き込み可能にする
dotnet_diagnostic.IDE0064.severity = warning
# 'System.HashCode.Combine' を使用する
dotnet_diagnostic.IDE0070.severity = suggestion
# 不足しているケースを switch 式に追加する
dotnet_diagnostic.IDE0072.severity = suggestion
# 不要な抑制演算子を削除する
dotnet_diagnostic.IDE0080.severity = warning
# typeof を nameof に変換する | typeof(C).Name -> nameof(C)
dotnet_diagnostic.IDE0082.severity = warning
# 不要な等値演算子を削除する
dotnet_diagnostic.IDE0100.severity = warning
# 不要な破棄項目を削除する
dotnet_diagnostic.IDE0110.severity = warning
# LINQ 式を簡略化する | .Where(predicate).Any() -> .Any(predicate)
dotnet_diagnostic.IDE0120.severity = warning
# LINQ の型チェックとキャストを簡素化する | .Where(a => a is int).Cast<int>() -> .OfType<int>()
dotnet_diagnostic.IDE0121.severity = warning
# null 許容ディレクティブが冗長, 不要
dotnet_diagnostic.IDE0240.severity = suggestion
dotnet_diagnostic.IDE0241.severity = suggestion
# 属性で nameof 式を使用する
dotnet_diagnostic.IDE0280.severity = warning
